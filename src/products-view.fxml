<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="10.0" xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.miniproject2.controller.ProductsController">

    <padding>
        <Insets top="15" right="15" bottom="15" left="15"/>
    </padding>

    <Label text="Products Management" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>

    <TextField fx:id="idField" promptText="Product ID"/>
    <TextField fx:id="nameField" promptText="Product Name"/>
    <TextField fx:id="priceField" promptText="Product Price"/>

    <HBox spacing="10">
        <Button text="Add" onAction="#addProduct"/>
        <Button text="Update" onAction="#updateProduct"/>
        <Button text="Delete" onAction="#deleteProduct"/>
        <Button text="Clear" onAction="#clearFields"/>
        <Button text="Back Home" onAction="#backHome"/>
    </HBox>

    <TableView fx:id="tableView" prefHeight="300">
        <columns>
            <TableColumn fx:id="idColumn" text="ID" prefWidth="120"/>
            <TableColumn fx:id="nameColumn" text="Name" prefWidth="250"/>
            <TableColumn fx:id="priceColumn" text="Price" prefWidth="150"/>
        </columns>
    </TableView>

    <Label fx:id="messageLabel"/>
</VBox>